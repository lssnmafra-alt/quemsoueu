{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/rooms/[id]/bot-turn",
      "regex": "^/api/rooms/([^/]+?)/bot\\-turn(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/rooms/(?<nxtPid>[^/]+?)/bot\\-turn(?:/)?$"
    },
    {
      "page": "/api/rooms/[id]/finalize-picking",
      "regex": "^/api/rooms/([^/]+?)/finalize\\-picking(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/rooms/(?<nxtPid>[^/]+?)/finalize\\-picking(?:/)?$"
    },
    {
      "page": "/api/rooms/[id]/heartbeat",
      "regex": "^/api/rooms/([^/]+?)/heartbeat(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/rooms/(?<nxtPid>[^/]+?)/heartbeat(?:/)?$"
    },
    {
      "page": "/api/rooms/[id]/leave",
      "regex": "^/api/rooms/([^/]+?)/leave(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/rooms/(?<nxtPid>[^/]+?)/leave(?:/)?$"
    },
    {
      "page": "/api/rooms/[id]/start",
      "regex": "^/api/rooms/([^/]+?)/start(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/rooms/(?<nxtPid>[^/]+?)/start(?:/)?$"
    },
    {
      "page": "/api/rooms/[id]/turn-timeout",
      "regex": "^/api/rooms/([^/]+?)/turn\\-timeout(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/rooms/(?<nxtPid>[^/]+?)/turn\\-timeout(?:/)?$"
    },
    {
      "page": "/decks/[id]",
      "regex": "^/decks/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/decks/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/room/[id]",
      "regex": "^/room/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/room/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/decks",
      "regex": "^/decks(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/decks(?:/)?$"
    },
    {
      "page": "/lobby",
      "regex": "^/lobby(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/lobby(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}