# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=

# POLLINATIONS AI
POLLINATIONS_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=

# GROQ
GROQ_API_KEY=

# OPENROUTER
# Used for bot communication and personality logic.
# Get your key at https://openrouter.ai/
OPENROUTER_API_KEY=

# CLOUDFLARE R2
R2_BUCKET_NAME=
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=
R2_ACCOUNT_ID=

# SUPABASE 1 - Auth and Users
NEXT_PUBLIC_SUPABASE_URL_AUTH=
NEXT_PUBLIC_SUPABASE_ANON_KEY_AUTH=
SUPABASE_SERVICE_ROLE_KEY_AUTH=

# SUPABASE 2 - Game Data
NEXT_PUBLIC_SUPABASE_URL_GAME=
NEXT_PUBLIC_SUPABASE_ANON_KEY_GAME=
SUPABASE_SERVICE_ROLE_KEY_GAME=
